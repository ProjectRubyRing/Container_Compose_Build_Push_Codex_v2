#!/usr/bin/env bash

set -uo pipefail

if [ -n "${FAKE_DOCKER_CALLS:-}" ]; then
  printf '%s\n' "$*" >> "$FAKE_DOCKER_CALLS"
fi

fail() {
  printf 'fake docker: unsupported arguments: %s\n' "$*" >&2
  exit 64
}

is_cleaned() {
  [ -n "${FAKE_DOCKER_CLEANED:-}" ] && [ -f "$FAKE_DOCKER_CLEANED" ]
}

if [ "${1:-}" = "compose" ]; then
  shift
  subcommand=""
  for arg in "$@"; do
    case "$arg" in
      version|build|up|logs|ps|down)
        subcommand="$arg"
        break
        ;;
    esac
  done

  case "$subcommand" in
    version)
      printf 'Docker Compose version v2.29.0\n'
      ;;
    build)
      printf '[fake-build] BUILDKIT_PROGRESS=%s\n' "${BUILDKIT_PROGRESS:-unset}"
      if [ "${FAKE_DOCKER_BUILD_FAIL:-false}" = "true" ]; then
        printf 'fake compose build failed\n' >&2
        exit 42
      fi
      ;;
    up)
      printf 'fake app container started\n'
      ;;
    logs)
      if [ -z "${FAKE_COMPOSE_LOG_FILE:-}" ]; then
        printf 'FAKE_COMPOSE_LOG_FILE is not set\n' >&2
        exit 65
      fi
      last_arg="${!#}"
      if [ "$last_arg" = "db" ]; then
        for log_number in $(seq 1 52); do
          printf 'db-1  | DB%03d: companion service log\n' "$log_number"
        done
      elif [ "$last_arg" = "cache" ]; then
        printf 'cache-1  | CACHE001: cache ready\n'
        printf 'cache-1  | CACHE002: accepting connections\n'
      elif [ "$last_arg" = "cwagent" ]; then
        printf 'cwagent  | I! CloudWatch agent started\n'
        printf 'cwagent  | I! Log collection configured\n'
      elif [ "$last_arg" = "adot-collector" ] || [ "$last_arg" = "otel" ]; then
        printf 'adot-collector  | TracesExporter resource spans: 2, spans: 4\n'
      else
        cat "$FAKE_COMPOSE_LOG_FILE"
      fi
      ;;
    ps)
      if [[ " $* " == *" --services "* ]]; then
        for fake_service in ${FAKE_COMPOSE_PS_SERVICES:-app}; do
          printf '%s\n' "$fake_service"
        done
      else
        case "${!#}" in
          cwagent) printf 'cid-cwagent\n' ;;
          cloudwatch-logs-mock) printf 'cid-cloudwatch-logs-mock\n' ;;
          adot-collector|otel) printf 'cid-adot-collector\n' ;;
          jaeger) printf 'cid-jaeger\n' ;;
          *) printf 'cid-app\n' ;;
        esac
      fi
      ;;
    down)
      printf 'fake app container removed\n'
      ;;
    *)
      fail "compose $*"
      ;;
  esac
  exit 0
fi

if [ "${1:-}" = "context" ] && [ "${2:-}" = "show" ]; then
  printf 'default\n'
  exit 0
fi

if [ "${1:-}" = "context" ] && [ "${2:-}" = "inspect" ]; then
  printf 'unix:///var/run/docker.sock\n'
  exit 0
fi

if [ "${1:-}" = "port" ] && [ "${2:-}" = "cid-app" ] && [ "${3:-}" = "8080/tcp" ]; then
  printf '0.0.0.0:18080\n'
  exit 0
fi

if [ "${1:-}" = "port" ] && [ "${2:-}" = "cid-cloudwatch-logs-mock" ] && [ "${3:-}" = "8080/tcp" ]; then
  printf '0.0.0.0:18480\n'
  exit 0
fi

if [ "${1:-}" = "port" ] && [ "${2:-}" = "cid-jaeger" ] && [ "${3:-}" = "16686/tcp" ]; then
  printf '0.0.0.0:16686\n'
  exit 0
fi

if [ "${1:-}" = "system" ] && [ "${2:-}" = "df" ]; then
  if is_cleaned; then
    printf 'Images|0 B\n'
    printf 'Containers|0 B\n'
    printf 'Local Volumes|0 B\n'
    printf 'Build Cache|0 B\n'
  else
    printf 'Images|2 GB\n'
    printf 'Containers|100 MB\n'
    printf 'Local Volumes|500 MB\n'
    printf 'Build Cache|400 MB\n'
  fi
  exit 0
fi

if [ "${1:-}" = "system" ] && [ "${2:-}" = "prune" ]; then
  if [ -n "${FAKE_DOCKER_CLEANED:-}" ]; then
    : > "$FAKE_DOCKER_CLEANED"
  fi
  printf 'Total reclaimed space: 0B\n'
  exit 0
fi

if [ "${1:-}" = "info" ]; then
  # ホスト側 df の値は環境依存になるため、Docker 管理対象容量だけをテストする。
  exit 65
fi

if [ "${1:-}" = "container" ]; then
  case "${2:-}" in
    ls)
      if ! is_cleaned; then
        if [ "$*" = "container ls -q --filter status=paused" ]; then
          printf 'cid-paused\n'
        else
          case "${3:-}" in
            -q)  printf 'cid-running\ncid-paused\n' ;;
            -aq) printf 'cid-running\ncid-paused\ncid-stopped\n' ;;
            *) fail "$@" ;;
          esac
        fi
      fi
      ;;
    unpause)
      shift 2
      printf '%s\n' "$@"
      ;;
    stop)
      shift 2
      printf '%s\n' "$@"
      ;;
    prune)
      printf 'Total reclaimed space: 100MB\n'
      ;;
    *)
      fail "$@"
      ;;
  esac
  exit 0
fi

if [ "${1:-}" = "builder" ] && [ "${2:-}" = "prune" ]; then
  printf 'Total: 400MB\n'
  exit 0
fi

if [ "${1:-}" = "image" ] && [ "${2:-}" = "ls" ]; then
  if ! is_cleaned; then
    printf 'sha256:image-one\nsha256:image-two\n'
  fi
  exit 0
fi

if [ "${1:-}" = "image" ] && [ "${2:-}" = "prune" ]; then
  printf 'Total reclaimed space: 2GB\n'
  exit 0
fi

if [ "${1:-}" = "image" ] && [ "${2:-}" = "inspect" ]; then
  case "$*" in
    *".Config.Env"*)
      printf 'PATH=/usr/bin\n'
      ;;
    *)
      printf 'sha256:test-image|2026-07-18T00:00:00Z|12345\n'
      ;;
  esac
  exit 0
fi

if [ "${1:-}" = "volume" ] && [ "${2:-}" = "ls" ]; then
  if ! is_cleaned; then
    printf 'volume-one\nvolume-two\n'
  fi
  exit 0
fi

if [ "${1:-}" = "volume" ] && [ "${2:-}" = "prune" ]; then
  printf 'Total reclaimed space: 500MB\n'
  exit 0
fi

if [ "${1:-}" = "network" ] && [ "${2:-}" = "ls" ]; then
  if ! is_cleaned; then
    printf 'network-one\n'
  fi
  exit 0
fi

if [ "${1:-}" = "network" ] && [ "${2:-}" = "prune" ]; then
  printf 'Deleted Networks:\nnetwork-one\n'
  exit 0
fi

if [ "${1:-}" = "inspect" ]; then
  case "$*" in
    *".State.Running"*)
      printf 'true\n'
      ;;
    *"com.docker.compose.service"*)
      printf 'app\n'
      ;;
    *"{{.Name}}"*)
      case "$*" in
        *"cid-cwagent"*) printf '/cwagent\n' ;;
        *"cid-cloudwatch-logs-mock"*) printf '/cloudwatch-logs-mock\n' ;;
        *"cid-adot-collector"*) printf '/adot-collector\n' ;;
        *"cid-jaeger"*) printf '/jaeger\n' ;;
        *) printf '/test-app-1\n' ;;
      esac
      ;;
    *".NetworkSettings.Networks"*)
      printf '172.20.0.2\n'
      ;;
    *"{{.Image}}"*)
      printf 'fake-image\n'
      ;;
    *".Config.Env"*)
      printf 'PATH=/usr/bin\n'
      ;;
    *)
      fail "$@"
      ;;
  esac
  exit 0
fi

if [ "${1:-}" = "exec" ] && [ "${2:-}" = "cid-cwagent" ] \
    && [ "${3:-}" = "cat" ] && [ "${4:-}" = "/etc/cwagentconfig/cwagent-config.json" ]; then
  cat <<'JSON'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/mnt/logs/app-front*.log",
            "log_group_name": "/local/myapp/efs/app-front",
            "log_stream_name": "front-local"
          },
          {
            "file_path": "/mnt/logs/app-back*.log",
            "log_group_name": "/local/myapp/efs/app-back",
            "log_stream_name": "back-local"
          }
        ]
      }
    }
  }
}
JSON
  exit 0
fi

if [ "${1:-}" = "exec" ] && [ "${2:-}" = "cid-adot-collector" ] \
    && [ "${3:-}" = "/healthcheck" ]; then
  exit 0
fi

emit_fake_find_entry() {
  local entry_path="$1" relative entry_depth=0 pruned_path
  for pruned_path in "${fake_find_pruned_paths[@]}"; do
    if [ "$entry_path" = "$pruned_path" ]; then
      [ "$fake_find_type" = "d" ] || return 0
      break
    fi
    if [[ "$entry_path" == "$pruned_path/"* ]]; then
      return 0
    fi
  done
  if [ "$fake_find_root" = "/" ]; then
    relative="${entry_path#/}"
  elif [ "$entry_path" = "$fake_find_root" ]; then
    relative=""
  elif [[ "$entry_path" == "$fake_find_root/"* ]]; then
    relative="${entry_path#"$fake_find_root"/}"
  else
    return 0
  fi
  while [ -n "$relative" ]; do
    entry_depth=$((entry_depth + 1))
    case "$relative" in
      */*) relative="${relative#*/}" ;;
      *) relative="" ;;
    esac
  done
  if [ "$fake_find_max_depth" = "all" ] || [ "$entry_depth" -le "$fake_find_max_depth" ]; then
    printf '%s\0' "$entry_path"
  fi
}

if [ "${1:-}" = "exec" ] && [ "${3:-}" = "find" ]; then
  if [ "${FAKE_DOCKER_FIND_FAIL:-false}" = "true" ]; then
    printf 'find: not found\n' >&2
    exit 127
  fi

  fake_find_type=""
  fake_find_max_depth="all"
  fake_find_root="${4:-/}"
  fake_find_next=""
  fake_find_pruned_paths=()
  for arg in "$@"; do
    if [ "$fake_find_next" = "type" ]; then
      fake_find_type="$arg"
      fake_find_next=""
      continue
    fi
    if [ "$fake_find_next" = "maxdepth" ]; then
      fake_find_max_depth="$arg"
      fake_find_next=""
      continue
    fi
    if [ "$fake_find_next" = "path" ]; then
      fake_find_pruned_paths+=("$arg")
      fake_find_next=""
      continue
    fi
    case "$arg" in
      -type) fake_find_next="type" ;;
      -maxdepth) fake_find_next="maxdepth" ;;
      -path) fake_find_next="path" ;;
    esac
  done

  case "$fake_find_type" in
    d)
      fake_find_entries=(
        "/"
        "/afs"
        "/afs/cache"
        "/app"
        "/app/config"
        "/app/config/nested"
        "/aws"
        "/aws/runtime"
        "/empty"
        "/etc"
        "/etc/ssl"
        "/local"
        "/local/aws-cli"
        "/local/aws-cli/aws-cli-hidden"
        "/opt"
        "/opt/app"
        "/opt/app/config"
        "/opt/eap"
        "/opt/eap/standalone"
        "/opt/eap/standalone/deployments"
        "/opt/eap/standalone/deployments/orders.war"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes"
        "/opt/jboss-eap"
        "/opt/jboss-eap/.galleon"
        "/opt/jboss-eap/.galleon/galleon-hidden"
        "/opt/jboss-eap/modules"
        "/opt/jboss-eap/modules/system"
        "/opt/jboss-eap/modules/system/layers"
        "/opt/jboss-eap/modules/system/layers/base"
        "/opt/jboss-eap/modules/system/layers/base/jboss-base-hidden"
        "/proc"
        "/proc/1"
        "/sys"
        "/sys/kernel"
        "/usr"
        "/usr/lib"
        "/usr/lib/jvm"
        "/usr/lib64"
        "/usr/lib64/lib64-hidden"
        "/usr/local"
        "/usr/local/usr-local-hidden"
        "/usr/share"
        "/usr/share/X11"
        "/usr/share/X11/X11-hidden"
        "/usr/share/doc"
        "/usr/share/doc/doc-hidden"
        "/usr/share/icons"
        "/usr/share/icons/icons-hidden"
        "/usr/share/licenses"
        "/usr/share/licenses/licenses-hidden"
        "/usr/share/man"
        "/usr/share/man/man-hidden"
        "/usr/share/osinfo"
        "/usr/share/osinfo/osinfo-hidden"
        "/usr/share/public"
        "/usr/share/public/assets"
        "/usr/share/zoneinfo"
        "/usr/share/zoneinfo/zoneinfo-hidden"
      )
      ;;
    f)
      fake_find_entries=(
        "/LICENSE"
        "/afs/cache/index"
        "/app/application.jar"
        "/app/legacy.jar"
        "/app/archive.tar.gz"
        "/app/config/application.yaml"
        "/app/config/override.yaml"
        "/app/config/.env"
        "/app/config/nested/deep.json"
        "/aws/runtime/metadata.json"
        "/etc/hosts"
        "/local/aws-cli/aws-cli-hidden.txt"
        "/opt/app/config/override.properties"
        "/opt/app/config/runtime.properties"
        "/opt/eap/standalone/deployments/orders.war.deployed"
        "/opt/eap/standalone/deployments/orders.war/index.jsp"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/web.xml"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order01.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order02.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order03.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order04.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order05.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order06.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order07.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order08.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order09.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order10.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/Order11.class"
        "/opt/eap/standalone/deployments/orders.war/WEB-INF/classes/application.properties"
        "/opt/jboss-eap/.galleon/state"
        "/opt/jboss-eap/modules/system/layers/base/jboss-base-hidden.xml"
        "/proc/1/status"
        "/sys/kernel/uevent_seqnum"
        "/usr/lib/libexample.so"
        "/usr/lib64/lib64-hidden.so"
        "/usr/local/usr-local-hidden.txt"
        "/usr/share/X11/X11-hidden.txt"
        "/usr/share/doc/doc-hidden.txt"
        "/usr/share/icons/icons-hidden.txt"
        "/usr/share/licenses/licenses-hidden.txt"
        "/usr/share/man/man-hidden.txt"
        "/usr/share/osinfo/osinfo-hidden.txt"
        "/usr/share/public/readme.txt"
        "/usr/share/public/assets/logo.svg"
        "/usr/share/zoneinfo/zoneinfo-hidden.txt"
        "/usr/share/zoneinfo.txt"
      )
      ;;
    *)
      fail "$@"
      ;;
  esac
  for fake_find_entry in "${fake_find_entries[@]}"; do
    emit_fake_find_entry "$fake_find_entry"
  done
  exit 0
fi

if [ "${1:-}" = "exec" ]; then
  printf 'APP_CONFIG_DIR=/opt/app/config\n'
  printf 'API_TOKEN=do-not-log-this-value\n'
  printf 'PATH=/usr/bin\n'
  exit 0
fi

fail "$@"
